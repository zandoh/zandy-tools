{
	"$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/main/crates/emmylua_code_analysis/resources/schema.json",
	"runtime": {
		"version": "Lua5.1"
	},
	"workspace": {
		"ignoreDir": ["ZandyTools/Libs", ".release", "docs", "scripts"]
	},
	"diagnostics": {
		"disable": ["undefined-global", "undefined-field", "inject-field", "unnecessary-if"]
	}
}
